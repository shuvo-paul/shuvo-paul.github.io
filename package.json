{
  "name": "shuvo-paul.github.io",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:css": "tailwindcss -i ./assets/css/main.css -o ./static/css/main.css --watch",
    "build:css": "tailwindcss -i ./assets/css/main.css -o ./static/css/main.css --minify",
    "dev": "npm run build:css && hugo server",
    "build": "npm run build:css && hugo --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "postcss-cli": "^10.1.0",
    "tailwindcss": "^3.3.2"
  }
}
